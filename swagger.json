{
  "swagger": "2.0",
  "info": {
    "title": "Marvel API",
    "description": "API for Marvel Characters, Movies, and Comics with OAuth authentication",
    "version": "1.0.0"
  },
  "host": "localhost:5050",
  "basePath": "/",
  "schemes": ["http"],
  "securityDefinitions": {
  "googleOAuth": {
    "type": "oauth2",
    "authorizationUrl": "https://accounts.google.com/o/oauth2/auth",
    "flow": "implicit",
    "scopes": {
      "profile": "Access to your basic profile info",
      "email": "Access to your email address"
    }
  }
},
  "paths": {
    "/api/characters": {
      "get": {
        "summary": "Get all characters",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "responses": {
          "200": { "description": "List of characters" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "summary": "Create a new character",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "parameters": [
          {
            "name": "body",
            "in": "body",
            "required": true,
            "schema": { "$ref": "#/definitions/Character" }
          }
        ],
        "responses": {
          "201": { "description": "Character created" },
          "400": { "description": "Invalid data" }
        }
      }
    },
    "/api/characters/{id}": {
      "get": {
        "summary": "Get character by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Character found" },
          "404": { "description": "Character not found" },
          "400": { "description": "Invalid ID" }
        }
      },
      "put": {
        "summary": "Update character by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Character" } }
        ],
        "responses": {
          "200": { "description": "Character updated" },
          "404": { "description": "Character not found" },
          "400": { "description": "Invalid data" }
        }
      },
      "delete": {
        "summary": "Delete character by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Character deleted" },
          "404": { "description": "Character not found" },
          "400": { "description": "Invalid ID" }
        }
      }
    },

    "/api/movies": {
      "get": {
        "summary": "Get all movies",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "responses": {
          "200": { "description": "List of movies" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "summary": "Create a new movie",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Movie" } }
        ],
        "responses": {
          "201": { "description": "Movie created" },
          "400": { "description": "Invalid data" }
        }
      }
    },
    "/api/movies/{id}": {
      "get": {
        "summary": "Get movie by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Movie found" },
          "404": { "description": "Movie not found" },
          "400": { "description": "Invalid ID" }
        }
      },
      "put": {
        "summary": "Update movie by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Movie" } }
        ],
        "responses": {
          "200": { "description": "Movie updated" },
          "404": { "description": "Movie not found" },
          "400": { "description": "Invalid data" }
        }
      },
      "delete": {
        "summary": "Delete movie by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Movie deleted" },
          "404": { "description": "Movie not found" },
          "400": { "description": "Invalid ID" }
        }
      }
    },

    "/api/comics": {
      "get": {
        "summary": "Get all comics",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "responses": {
          "200": { "description": "List of comics" },
          "500": { "description": "Internal Server Error" }
        }
      },
      "post": {
        "summary": "Create a new comic",
        "security": [
            { "googleOAuth": ["profile", "email"] }
        ],
        "parameters": [
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Comic" } }
        ],
        "responses": {
          "201": { "description": "Comic created" },
          "400": { "description": "Invalid data" }
        }
      }
    },
    "/api/comics/{id}": {
      "get": {
        "summary": "Get comic by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Comic found" },
          "404": { "description": "Comic not found" },
          "400": { "description": "Invalid ID" }
        }
      },
      "put": {
        "summary": "Update comic by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" },
          { "name": "body", "in": "body", "required": true, "schema": { "$ref": "#/definitions/Comic" } }
        ],
        "responses": {
          "200": { "description": "Comic updated" },
          "404": { "description": "Comic not found" },
          "400": { "description": "Invalid data" }
        }
      },
      "delete": {
        "summary": "Delete comic by ID",
        "parameters": [
          { "name": "id", "in": "path", "required": true, "type": "string" }
        ],
        "responses": {
          "200": { "description": "Comic deleted" },
          "404": { "description": "Comic not found" },
          "400": { "description": "Invalid ID" }
        }
      }
    }
  },

  "definitions": {
    "Character": {
      "type": "object",
      "required": ["name", "universe"],
      "properties": {
        "name": { "type": "string", "example": "Peter Parker" },
        "alias": { "type": "string", "example": "Spider-Man" },
        "universe": { "type": "string", "example": "MCU" },
        "firstAppearance": { "type": "string", "example": "Amazing Fantasy #15" },
        "powers": { "type": "array", "items": { "type": "string" }, "example": ["Wall-crawling", "Spider-Sense"] },
        "movies": { "type": "array", "items": { "type": "string" }, "example": ["movieId1"] },
        "comics": { "type": "array", "items": { "type": "string" }, "example": ["comicId1"] }
      }
    },
    "Movie": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "example": "Avengers: Endgame" },
        "releaseDate": { "type": "string", "example": "2019-04-26" },
        "characters": { "type": "array", "items": { "type": "string" }, "example": ["characterId1"] }
      }
    },
    "Comic": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": { "type": "string", "example": "Amazing Spider-Man #1" },
        "releaseDate": { "type": "string", "example": "1963-03-01" },
        "characters": { "type": "array", "items": { "type": "string" }, "example": ["characterId1"] }
      }
    }
  }
}